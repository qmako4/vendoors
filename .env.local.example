# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare R2 (photo storage — free egress)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=vendoors-photos
# Public read URL for the bucket (R2.dev subdomain or custom domain).
# When set, photos resolve from R2 instead of Supabase Storage.
NEXT_PUBLIC_R2_PUBLIC_URL=

# Resend
RESEND_API_KEY=
RESEND_FROM=hello@vendoors.co

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STUDIO=
STRIPE_PRICE_ATELIER=

# Cloudflare Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Anthropic (auto-product detection from library images)
ANTHROPIC_API_KEY=

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000
